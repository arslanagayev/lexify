DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=sqlite+aiosqlite:///./vocabulary.db
REMINDER_HOUR=9
REMINDER_MINUTE=0

# Auth — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Gmail SMTP — use an App Password (not your account password)
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_ADDRESS=yourname@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
